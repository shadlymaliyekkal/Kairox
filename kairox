#!/usr/bin/env bash
set -euo pipefail

# -------------------------------
# KAIROX Launcher
# -------------------------------

# FIX: Use BASH_SOURCE[0] — works correctly when sourced or called via symlink
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

VENV_PYTHON="$SCRIPT_DIR/venv/bin/python"
KAIROX="$SCRIPT_DIR/kairox.py"

# FIX: Check venv exists before trying to use it
if [ ! -f "$VENV_PYTHON" ]; then
    echo "[!] Virtual environment not found."
    echo "    Run './install.sh' first to set up KAIROX."
    exit 1
fi

# FIX: Check kairox.py exists
if [ ! -f "$KAIROX" ]; then
    echo "[!] kairox.py not found in $SCRIPT_DIR"
    exit 1
fi

# FIX: Respect existing GOPATH if set; fall back to ~/go/bin
GOPATH_BIN="${GOPATH:-$HOME/go}/bin"
export PATH="$PATH:$GOPATH_BIN"

# FIX: Forward exit code from Python back to the caller
exec "$VENV_PYTHON" "$KAIROX" "$@"
